# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
APP_NAME=Agent Demo Backend
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://192.168.0.108:3000"]

# ──────────────────────────────────────────────
# JWT / Auth
# ──────────────────────────────────────────────
JWT_SECRET_KEY=test-secret-key-for-jwt-signing-only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27018
MONGO_DB_NAME=agent_demo_backend
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_DEFAULT_TTL=3600

# ──────────────────────────────────────────────
# LangCache
# ──────────────────────────────────────────────
LANG_CACHE_SERVICE_URL=
LANG_CACHE_ID=
LANG_CACHE_API_KEY=

# ──────────────────────────────────────────────
# Qdrant
# ──────────────────────────────────────────────
QDRANT_URI=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=true

# ──────────────────────────────────────────────
# OpenAI
# ──────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_LLM_MODEL=gpt-4o
OPENAI_LLM_TEMPERATURE=0.2
OPENAI_LLM_MAX_TOKENS=1024

# ──────────────────────────────────────────────
# SQL Server
# ──────────────────────────────────────────────
SQL_DRIVER=ODBC Driver 18 for SQL Server

# ──────────────────────────────────────────────
# LlamaIndex
# ──────────────────────────────────────────────
LLAMA_INDEX_CHUNK_SIZE=1024
LLAMA_INDEX_CHUNK_OVERLAP=128
LLAMA_INDEX_SQL_TOP_K=5

# ──────────────────────────────────────────────
# MCP Tool Servers
# ──────────────────────────────────────────────
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
MCP_TOOL_TIMEOUT=30

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60